    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "download:images": "node scripts/download-remote-images.mjs",
    "download:ui-images": "node scripts/download-remote-images.mjs \"..\\UI\" \"public/images/ui-imported\"",
